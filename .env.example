# LLM
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Your Slack user ID (Settings → Profile → three-dot menu → Copy member ID)
# Used by the task runner to DM you proactively
SLACK_USER_ID=U...

# Agent Slack tokens live in agents/<id>/.env (see agents/forge/.env.example)
# Fallback: root .env tokens using SLACK_BOT_TOKEN_<ID_UPPERCASE> convention
# SLACK_BOT_TOKEN_FORGE=xoxb-...
# SLACK_APP_TOKEN_FORGE=xapp-...

# GITHUB_TOKEN=ghp-...
# BRAVE_API_KEY=...
